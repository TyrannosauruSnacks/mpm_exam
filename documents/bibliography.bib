@misc{krammBetriebszielorientiereInventurUnd2010,
  title = {Betriebszielorientiere Inventur und Schadensbewertung von Schalenwildverbiss},
  shorttitle = {BISS},
  author = {Kramm, Doris and Köhnemann, Berit},
  date = {2010},
  url = {https://www.hnee.de/de/Fachbereiche/Wald-und-Umwelt/Wildschden-im-Wald-BISS-E7558.htm},
  urldate = {2024-11-03},
  abstract = {Vor dem Hintergrund der Bewertung von schädlichem Wildverbiss ist allein die Aufnahme von Verbiss in den Be- ständen in der Erneuerungsphase relevant. Aus ökologisch- waldbaulicher Sicht für eine ökonomisch-monetäre Evaluie- rung ist außerdem hauptsächlich der Verbiss an den Ziel- baumarten in den jeweiligen Beständen interessant. Die laut Betriebsziel verjüngungsfähigen Bestände werden vor der Aufnahme im Feld anhand von Luftbildern nach objektiven Kriterien ausgewählt. Die Auswahl der Aufnah- mepunkte für die Geländeerhebung erfolgt durch ein sys- tematisches Raster. Im Gelände werden die Aufnahme- punkte anhand ihrer Sollkoordinaten mittels GPS-Gerät aufgesucht. Für jede Zielbaumart werden nachein- ander die nächsten n Bäume zum Probekreismittelpunkt aufgenommen, bis entweder n = 20 Individuen der jeweilig Zielbaumart erfasst sind, oder der Radius von 5 m erreicht ist. Die Entfernung der 20. Verjüngungs- pflanze jeder Zielbaumart zum Mittel- punkt wird gemessen. Es werden Verjüngungspflanzen von 0 bis 200 cm (ohne Keimlinge) auf frischen Leittriebverbiss untersucht und 5 Höhenklassen zugeordnet},
  langid = {german},
  organization = {Hochschule für nachhaltige Entwicklung Eberswalde},
  keywords = {methods,monitoring methods,wildeinfluss,Wildlife conservation,wildlife management},
  file = {/home/max/Zotero/storage/65ITW4U9/Verfahrensbeschreibung_BISS_0610.pdf;/home/max/Zotero/storage/EWPRWYYH/Stöcker - Betriebszielorientierte Inventur und Schadensbewer.pdf}
}

